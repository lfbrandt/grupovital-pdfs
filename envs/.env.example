# ─────────────────────────────────────────────────────────────────────────────
# Grupo Vital PDFs — Exemplo de variáveis de ambiente
# Copie este arquivo para envs/.env.development (dev) ou envs/.env.production
# e preencha os valores reais. NUNCA comite arquivos .env com segredos reais.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
FLASK_ENV=development           # development | production

# Versão do app — altere a cada deploy para forçar cache busting de CSS/JS
# Exemplo em produção: alpha-1.1.3
APP_VERSION=dev

# Canal/label exibido no rodapé junto com APP_VERSION (opcional)
APP_CHANNEL=

# ID de build usado no cookie gv_build (padrão: igual a APP_VERSION)
APP_BUILD_ID=

# ── Segurança ─────────────────────────────────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria
ADMIN_TOKEN=

# Diretório persistente e gravável pelo usuário do serviço para feedbacks.
# Vazio em desenvolvimento usa o fallback instance/feedback.
# Em produção, recomenda-se configurar um caminho absoluto persistente.
FEEDBACK_DIR=

# ── Upload ────────────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800     # 50 MB em bytes
UPLOAD_TTL_HOURS=24

# ── HTTPS / HSTS ─────────────────────────────────────────────────────────────
FORCE_HTTPS=false               # true em produção atrás de proxy TLS
HSTS_MAX_AGE=31536000
SESSION_COOKIE_SECURE=false     # true em produção

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATELIMIT_STORAGE_URI=memory://
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0   # usar em produção com Redis

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_DIR=/opt/vital-pdf/logs
FILE_LOG_LEVEL=DEBUG
CONSOLE_LOG_LEVEL=INFO
