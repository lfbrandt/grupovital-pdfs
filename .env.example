# Exemplo de variáveis de ambiente
SECRET_KEY=sua-chave-secreta
MAX_CONTENT_LENGTH=16777216  # 16 MB, ajuste se precisar
#HOST=127.0.0.1
#PORT=5000

# Caminho opcional para o executável do LibreOffice (soffice)
#LIBREOFFICE_BIN=/usr/bin/libreoffice

# ── Ghostscript — resolução do binário ───────────────────────────────────────
# Todos os serviços (compress, merge, converter) aceitam os três aliases abaixo,
# verificados nesta ordem de prioridade:
#
#   1. GS_BIN          — nome canônico do projeto (recomendado)
#   2. GHOSTSCRIPT_BIN — alias de compatibilidade (Dockerfiles / READMEs antigos)
#   3. GS_PATH         — alias legado do compress_service anterior
#
# Defina apenas UM deles. Se nenhum for definido, o serviço tenta localizar
# gswin64c / gswin32c (Windows) ou gs (Linux/macOS) automaticamente via PATH.
#
# Linux/macOS:
#GS_BIN=/usr/bin/gs
#
# Windows (se gswin64c não estiver no PATH do sistema):
#GS_BIN=C:\Program Files\gs\gs10.05.0\bin\gswin64c.exe

# Tempo limite (segundos) para o LibreOffice
#LIBREOFFICE_TIMEOUT=60

# Tempo limite (segundos) para o Ghostscript (padrão: 120)
#GS_TIMEOUT=120

# Força redirecionamento para HTTPS (true ou false)
#FORCE_HTTPS=true
